# FinNexus Environment Variables

# ==============================================
# BACKEND (FastAPI)
# ==============================================

# FastAPI Server
HOST=0.0.0.0
PORT=8000

# Gemini API Key (required for AI features)
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# News API (optional - falls back to mock data if not provided)
# Get from: https://newsdata.io/
NEWSDATA_API_KEY=your_newsdata_api_key_here

# FRED API (optional - for macroeconomic data)
# Get from: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# ==============================================
# FRONTEND (Next.js)
# ==============================================

# Backend API URL
# For local development: http://localhost:8000
# For production: https://your-backend-app.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# NewsData API (for frontend news display)
NEXT_PUBLIC_NEWSDATA_API_KEY=your_newsdata_api_key_here

# ==============================================
# PRODUCTION SETUP
# ==============================================
# 
# 1. Backend (Render):
#    - Set GOOGLE_API_KEY in Render environment variables
#    - Set NEWSDATA_API_KEY (optional)
#
# 2. Frontend (Vercel):
#    - Set NEXT_PUBLIC_API_URL to your Render backend URL
#    - Build command: npm run build
#    - Output directory: .next
